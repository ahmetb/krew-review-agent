# Multi-stage build for the Event Gateway (Fast-ACK Receiver).
# Build stage: compile the Go binary from golang:1.26.
FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /out/gateway ./cmd/gateway

# Runtime stage: minimal base with CA certificates for TLS to GCP Pub/Sub.
# Unlike the agent Dockerfile, git is not needed — the gateway does no cloning.
FROM alpine:3.20
RUN apk add --no-cache ca-certificates && update-ca-certificates
COPY --from=build /out/gateway /usr/local/bin/gateway
# Cloud Run expects the binary to listen on $PORT.
ENV PORT=8080
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/gateway"]
